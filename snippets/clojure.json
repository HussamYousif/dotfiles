{
  "Namespace": {
    "prefix": "ns",
    "body": [
      "(ns ${1:namespace-name}",
      "  (:require [${2:library} :as ${3:alias}]))"
    ],
    "description": "Namespace definition"
  },
  "Function": {
    "prefix": "defn",
    "body": [
      "(defn ${1:name}",
      "  \"${2:doc-string}\"",
      "  [${3:args}]",
      "  ${0:body})"
    ],
    "description": "Function definition"
  },
  "Private Function": {
    "prefix": "defn-",
    "body": [
      "(defn- ${1:name}",
      "  \"${2:doc-string}\"",
      "  [${3:args}]",
      "  ${0:body})"
    ],
    "description": "Private Function definition"
  },
  "Let binding": {
    "prefix": "let",
    "body": [
      "(let [${1:bindings}]",
      "  ${0:body})"
    ],
    "description": "Let binding"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "(if ${1:condition}",
      "  ${2:then}",
      "  ${3:else})"
    ],
    "description": "If statement"
  },
  "When statement": {
    "prefix": "when",
    "body": [
      "(when ${1:condition}",
      "  ${0:body})"
    ],
    "description": "When statement"
  },
  "Cond statement": {
    "prefix": "cond",
    "body": [
      "(cond",
      "  ${1:test} ${2:expression}",
      "  :else ${3:default})"
    ],
    "description": "Cond statement"
  },
  "Threading macro ->": {
    "prefix": "->",
    "body": [
      "(-> ${1:initial}",
      "    ${0:steps})"
    ],
    "description": "Thread-first macro"
  },
  "Threading macro ->>": {
    "prefix": "->>",
    "body": [
      "(->> ${1:initial}",
      "     ${0:steps})"
    ],
    "description": "Thread-last macro"
  },
  "Comment block": {
    "prefix": "comment",
    "body": [
      "(comment",
      "  ${0:body})"
    ],
    "description": "Comment block for REPL experiments"
  },
  "Def": {
    "prefix": "def",
    "body": [
      "(def ${1:name} ${2:value})"
    ],
    "description": "Define a var"
  },
  "Print line": {
    "prefix": "println",
    "body": [
      "(println ${1:message})"
    ],
    "description": "Print line"
  },
  "Try Catch": {
    "prefix": "try",
    "body": [
      "(try",
      "  ${1:body}",
      "  (catch ${2:Exception} ${3:e}",
      "    ${0:handler}))"
    ],
    "description": "Try/Catch block"
  },
  "Cond threading ->": {
    "prefix": "cond->",
    "body": [
      "(cond-> ${1:expr}",
      "  ${2:test} ${3:form}",
      "  ${0})"
    ],
    "description": "Conditional thread-first macro"
  },
  "Cond threading ->>": {
    "prefix": "cond->>",
    "body": [
      "(cond->> ${1:expr}",
      "  ${2:test} ${3:form}",
      "  ${0})"
    ],
    "description": "Conditional thread-last macro"
  },
  "Some threading ->": {
    "prefix": "some->",
    "body": [
      "(some-> ${1:expr}",
      "  ${0:forms})"
    ],
    "description": "Thread-first with nil short-circuit"
  },
  "Some threading ->>": {
    "prefix": "some->>",
    "body": [
      "(some->> ${1:expr}",
      "  ${0:forms})"
    ],
    "description": "Thread-last with nil short-circuit"
  },
  "As threading": {
    "prefix": "as->",
    "body": [
      "(as-> ${1:expr} ${2:name}",
      "  ${0:forms})"
    ],
    "description": "Thread with named binding"
  },
  "If-let": {
    "prefix": "if-let",
    "body": [
      "(if-let [${1:binding} ${2:test}]",
      "  ${3:then}",
      "  ${0:else})"
    ],
    "description": "If with let binding"
  },
  "When-let": {
    "prefix": "when-let",
    "body": [
      "(when-let [${1:binding} ${2:test}]",
      "  ${0:body})"
    ],
    "description": "When with let binding"
  },
  "If-not": {
    "prefix": "if-not",
    "body": [
      "(if-not ${1:condition}",
      "  ${2:then}",
      "  ${0:else})"
    ],
    "description": "If-not statement"
  },
  "When-not": {
    "prefix": "when-not",
    "body": [
      "(when-not ${1:condition}",
      "  ${0:body})"
    ],
    "description": "When-not statement"
  },
  "If-some": {
    "prefix": "if-some",
    "body": [
      "(if-some [${1:binding} ${2:test}]",
      "  ${3:then}",
      "  ${0:else})"
    ],
    "description": "If with some binding (non-nil check)"
  },
  "When-some": {
    "prefix": "when-some",
    "body": [
      "(when-some [${1:binding} ${2:test}]",
      "  ${0:body})"
    ],
    "description": "When with some binding (non-nil check)"
  },
  "When-first": {
    "prefix": "when-first",
    "body": [
      "(when-first [${1:binding} ${2:coll}]",
      "  ${0:body})"
    ],
    "description": "When with first element binding"
  },
  "Case": {
    "prefix": "case",
    "body": [
      "(case ${1:expr}",
      "  ${2:value} ${3:result}",
      "  ${0:default})"
    ],
    "description": "Case statement"
  },
  "Condp": {
    "prefix": "condp",
    "body": [
      "(condp ${1:pred} ${2:expr}",
      "  ${3:test} ${4:result}",
      "  ${0:default})"
    ],
    "description": "Condp statement"
  }
}
